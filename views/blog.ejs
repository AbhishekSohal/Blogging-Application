<!DOCTYPE html>
<html lang="en">

<head>
    <%- include('./partials/head') %>
        <title>BlogPage</title>
</head>

<body>
    <%- include('./partials/nav') %>
        <div class="container mt-3">
            <h1>
                <%= blog.title %>
            </h1>
            <img src="<%= blog.coverImageURL %>" class="img-fluid" alt="..." width="50%" height="auto" />
            <pre class="mt-3"><%= blog.content %></pre>

        </div>
        <div class="container mt-3">
            <img src="<%= blog.createdBy.profilePictureURL %>" class="rounded-circle" alt="..." width="50"
                height="50" />
            <span class="ms-2">
                <%= blog.createdBy.fullName %>
            </span>
        </div>
        <% if (locals.user && (locals.user._id === blog.createdBy._id.toString() || locals.user.id === blog.createdBy._id.toString())) { %>
            <div class="container mt-3">
                <a href="/blog/edit/<%= blog._id %>" class="btn btn-warning">Edit Blog</a>
                <form action="/blog/delete/<%= blog._id %>" method="POST" class="d-inline ms-2" onsubmit="return confirm('Are you sure you want to delete this blog post?');">
                    <button type="submit" class="btn btn-danger">Delete Blog</button>
                </form>
            </div>
        <% } %>
        <div class="container mt-3">
            <h1>Comments(<%=comments.length %>)</h1>
            <% if (locals.user) { %>
                <form action="/blog/comment/<%= blog.id %>" method="post">
                    <div class="mb-3">
                        <input type="text" class="form-control" id="content" name="content"
                            placeholder="Write a comment...">
                        <button type="submit" class="btn btn-primary mt-2">Submit</button>
                    </div>
                </form>
                <% } %>
                    <div class="mt-3">
                        <% comments.forEach(comment=> { %>
                            <div class="mb-3">
                                <img src="<%= (comment.createdBy && comment.createdBy.profilePictureURL) ? comment.createdBy.profilePictureURL : '/images/default.png' %>"
                                    class="rounded-circle" alt="..." width="50" height="50" />
                                <span class="ms-2">
                                    <%= (comment.createdBy && comment.createdBy.fullName) ? comment.createdBy.fullName
                                        : 'Guest User' %>
                                </span>
                                <pre class="ms-5 mt-2"><%= comment.content %></pre>
                            </div>
                            <% }) %>
                    </div>
        </div>

        <%- include('./partials/scripts') %>
</body>

</html>